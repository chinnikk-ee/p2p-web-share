# ─────────────────────────────────────────────────────────────
# Root environment example. Copy to .env for docker-compose, or
# copy the app-specific examples into apps/*/.env for local dev.
# ─────────────────────────────────────────────────────────────

# ── Backend (signaling server) ──────────────────────────────
NODE_ENV=development
BACKEND_PORT=4000
# Comma-separated list of allowed browser origins (CORS).
CORS_ORIGIN=http://localhost:5173
# Max signaling messages per socket per window (rate limiting).
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000
# Idle room time-to-live before cleanup (ms).
ROOM_TTL_MS=900000
# Heartbeat ping interval / timeout (ms).
HEARTBEAT_INTERVAL_MS=25000
HEARTBEAT_TIMEOUT_MS=60000
LOG_LEVEL=info

# Optional TURN relay (leave blank to use STUN only).
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=

# ── Frontend (Vite — must be prefixed with VITE_) ───────────
VITE_SIGNALING_URL=http://localhost:4000
VITE_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
# Optional TURN for the browser (usually injected by the backend /ice-config).
VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=

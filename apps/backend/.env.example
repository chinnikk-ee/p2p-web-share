# Signaling server configuration. Copy to .env for local development.

NODE_ENV=development
HOST=0.0.0.0
PORT=4000

# Comma-separated list of allowed browser origins, or "*" to reflect any.
CORS_ORIGIN=http://localhost:5173

# Per-socket signaling rate limit.
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000

# Room lifecycle.
ROOM_TTL_MS=900000
ROOM_SWEEP_INTERVAL_MS=60000
MAX_PEERS_PER_ROOM=8

# Socket.io heartbeat (liveness detection).
HEARTBEAT_INTERVAL_MS=25000
HEARTBEAT_TIMEOUT_MS=60000

LOG_LEVEL=info

# ICE configuration served at GET /ice-config.
STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=

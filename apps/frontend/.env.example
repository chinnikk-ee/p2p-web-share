# Frontend configuration. Copy to .env for local development.
# All variables MUST be prefixed with VITE_ to be exposed to the browser.

# URL of the signaling server.
VITE_SIGNALING_URL=http://localhost:4000

# Comma-separated STUN servers (fallback if the backend /ice-config is unreachable).
VITE_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# Optional TURN relay for restrictive networks (usually served by the backend).
VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
